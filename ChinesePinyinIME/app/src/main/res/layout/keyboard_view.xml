<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#E9EDF3"
    android:orientation="vertical"
    android:padding="6dp">

    <TextView
        android:id="@+id/keyboard_status"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:text="中文"
        android:textColor="#303744"
        android:textSize="14sp" />

    <LinearLayout
        android:id="@+id/candidate_bar"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="4dp">

        <LinearLayout
            android:id="@+id/candidate_list_container"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal" />

        <TextView
            android:id="@+id/candidate_expand_toggle"
            style="@style/CandidatePageButton"
            android:text="▴" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/candidate_expanded_panel"
        android:layout_width="match_parent"
        android:layout_height="144dp"
        android:background="#DDE5EF"
        android:fillViewport="true"
        android:paddingStart="4dp"
        android:paddingTop="4dp"
        android:paddingEnd="4dp"
        android:paddingBottom="4dp"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/candidate_expanded_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <LinearLayout
        android:id="@+id/letter_keyboard_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal">

            <Button style="@style/KeyboardKey" android:tag="key:q" android:text="q" />
            <Button style="@style/KeyboardKey" android:tag="key:w" android:text="w" />
            <Button style="@style/KeyboardKey" android:tag="key:e" android:text="e" />
            <Button style="@style/KeyboardKey" android:tag="key:r" android:text="r" />
            <Button style="@style/KeyboardKey" android:tag="key:t" android:text="t" />
            <Button style="@style/KeyboardKey" android:tag="key:y" android:text="y" />
            <Button style="@style/KeyboardKey" android:tag="key:u" android:text="u" />
            <Button style="@style/KeyboardKey" android:tag="key:i" android:text="i" />
            <Button style="@style/KeyboardKey" android:tag="key:o" android:text="o" />
            <Button style="@style/KeyboardKey" android:tag="key:p" android:text="p" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="14dp">

            <Button style="@style/KeyboardKey" android:tag="key:a" android:text="a" />
            <Button style="@style/KeyboardKey" android:tag="key:s" android:text="s" />
            <Button style="@style/KeyboardKey" android:tag="key:d" android:text="d" />
            <Button style="@style/KeyboardKey" android:tag="key:f" android:text="f" />
            <Button style="@style/KeyboardKey" android:tag="key:g" android:text="g" />
            <Button style="@style/KeyboardKey" android:tag="key:h" android:text="h" />
            <Button style="@style/KeyboardKey" android:tag="key:j" android:text="j" />
            <Button style="@style/KeyboardKey" android:tag="key:k" android:text="k" />
            <Button style="@style/KeyboardKey" android:tag="key:l" android:text="l" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/key_shift"
                style="@style/KeyboardShiftKey"
                android:layout_weight="0.65"
                android:tag="action:shift"
                android:text="⇧" />

            <Button style="@style/KeyboardKey" android:tag="key:z" android:text="z" />
            <Button style="@style/KeyboardKey" android:tag="key:x" android:text="x" />
            <Button style="@style/KeyboardKey" android:tag="key:c" android:text="c" />
            <Button style="@style/KeyboardKey" android:tag="key:v" android:text="v" />
            <Button style="@style/KeyboardKey" android:tag="key:b" android:text="b" />
            <Button style="@style/KeyboardKey" android:tag="key:n" android:text="n" />
            <Button style="@style/KeyboardKey" android:tag="key:m" android:text="m" />

            <Button
                android:id="@+id/key_delete"
                style="@style/KeyboardKey"
                android:layout_weight="1.2"
                android:tag="action:delete"
                android:text="DEL" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/t9_keyboard_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="144dp"
            android:orientation="horizontal">

            <!--
                Fixed-width column, always present (never toggled), so the digit
                grid's width never changes when pinyin choices appear/disappear -
                only the list contents inside change. This keeps the digit keys at
                a stable size instead of jumping every time the digit buffer edges
                in/out of an ambiguous match.
            -->
            <LinearLayout
                android:layout_width="64dp"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/t9_pinyin_choice_list"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />
                </ScrollView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal">

                    <Button style="@style/T9Key" android:tag="action:symbol" android:text="1\n符号" />
                    <Button style="@style/T9Key" android:tag="t9:2" android:text="2\nABC" />
                    <Button style="@style/T9Key" android:tag="t9:3" android:text="3\nDEF" />

                    <Button
                        style="@style/KeyboardKey"
                        android:tag="action:delete"
                        android:text="DEL" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal">

                    <Button style="@style/T9Key" android:tag="t9:4" android:text="4\nGHI" />
                    <Button style="@style/T9Key" android:tag="t9:5" android:text="5\nJKL" />
                    <Button style="@style/T9Key" android:tag="t9:6" android:text="6\nMNO" />

                    <Button
                        style="@style/KeyboardKey"
                        android:tag="action:retype"
                        android:text="重输" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal">

                    <Button style="@style/T9Key" android:tag="t9:7" android:text="7\nPQRS" />
                    <Button style="@style/T9Key" android:tag="t9:8" android:text="8\nTUV" />
                    <Button style="@style/T9Key" android:tag="t9:9" android:text="9\nWXYZ" />

                    <Button
                        style="@style/KeyboardKey"
                        android:tag="action:space"
                        android:text="0" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/symbol_keyboard_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/symbol_keyboard_en_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal">

                <Button style="@style/KeyboardKey" android:tag="sym:1" android:text="1" />
                <Button style="@style/KeyboardKey" android:tag="sym:2" android:text="2" />
                <Button style="@style/KeyboardKey" android:tag="sym:3" android:text="3" />
                <Button style="@style/KeyboardKey" android:tag="sym:4" android:text="4" />
                <Button style="@style/KeyboardKey" android:tag="sym:5" android:text="5" />
                <Button style="@style/KeyboardKey" android:tag="sym:6" android:text="6" />
                <Button style="@style/KeyboardKey" android:tag="sym:7" android:text="7" />
                <Button style="@style/KeyboardKey" android:tag="sym:8" android:text="8" />
                <Button style="@style/KeyboardKey" android:tag="sym:9" android:text="9" />
                <Button style="@style/KeyboardKey" android:tag="sym:0" android:text="0" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal">

                <Button style="@style/KeyboardKey" android:tag="sym:@" android:text="@" />
                <Button style="@style/KeyboardKey" android:tag="sym:#" android:text="#" />
                <Button style="@style/KeyboardKey" android:tag="sym:$" android:text="$" />
                <Button style="@style/KeyboardKey" android:tag="sym:%" android:text="%" />
                <Button style="@style/KeyboardKey" android:tag="sym:&amp;" android:text="&amp;" />
                <Button style="@style/KeyboardKey" android:tag="sym:*" android:text="*" />
                <Button style="@style/KeyboardKey" android:tag="sym:-" android:text="-" />
                <Button style="@style/KeyboardKey" android:tag="sym:+" android:text="+" />
                <Button style="@style/KeyboardKey" android:tag="sym:=" android:text="=" />
                <Button style="@style/KeyboardKey" android:tag="sym:/" android:text="/" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal">

                <Button style="@style/KeyboardKey" android:tag="sym:(" android:text="(" />
                <Button style="@style/KeyboardKey" android:tag="sym:)" android:text=")" />
                <Button style="@style/KeyboardKey" android:tag="sym::" android:text=":" />
                <Button style="@style/KeyboardKey" android:tag="sym:;" android:text=";" />
                <Button style="@style/KeyboardKey" android:tag="sym:'" android:text="'" />
                <Button style="@style/KeyboardKey" android:tag="sym:&quot;" android:text="&quot;" />
                <Button style="@style/KeyboardKey" android:tag="sym:?" android:text="?" />
                <Button style="@style/KeyboardKey" android:tag="sym:!" android:text="!" />
                <Button style="@style/KeyboardKey" android:tag="sym:." android:text="." />
                <Button style="@style/KeyboardKey" android:tag="sym:," android:text="," />

                <Button
                    style="@style/KeyboardKey"
                    android:layout_weight="1.3"
                    android:tag="action:delete"
                    android:text="DEL" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/symbol_keyboard_zh_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal">

                <Button style="@style/KeyboardKey" android:tag="sym:1" android:text="1" />
                <Button style="@style/KeyboardKey" android:tag="sym:2" android:text="2" />
                <Button style="@style/KeyboardKey" android:tag="sym:3" android:text="3" />
                <Button style="@style/KeyboardKey" android:tag="sym:4" android:text="4" />
                <Button style="@style/KeyboardKey" android:tag="sym:5" android:text="5" />
                <Button style="@style/KeyboardKey" android:tag="sym:6" android:text="6" />
                <Button style="@style/KeyboardKey" android:tag="sym:7" android:text="7" />
                <Button style="@style/KeyboardKey" android:tag="sym:8" android:text="8" />
                <Button style="@style/KeyboardKey" android:tag="sym:9" android:text="9" />
                <Button style="@style/KeyboardKey" android:tag="sym:0" android:text="0" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal">

                <Button style="@style/PunctuationKey" android:tag="punc:，" android:text="，" />
                <Button style="@style/PunctuationKey" android:tag="punc:。" android:text="。" />
                <Button style="@style/PunctuationKey" android:tag="punc:？" android:text="？" />
                <Button style="@style/PunctuationKey" android:tag="punc:！" android:text="！" />
                <Button style="@style/PunctuationKey" android:tag="punc:：" android:text="：" />
                <Button style="@style/PunctuationKey" android:tag="punc:；" android:text="；" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal">

                <Button style="@style/PunctuationKey" android:tag="punc:、" android:text="、" />
                <Button style="@style/PunctuationKey" android:tag="punc:“" android:text="“" />
                <Button style="@style/PunctuationKey" android:tag="punc:”" android:text="”" />
                <Button style="@style/PunctuationKey" android:tag="punc:（" android:text="（" />
                <Button style="@style/PunctuationKey" android:tag="punc:）" android:text="）" />

                <Button
                    style="@style/KeyboardKey"
                    android:layout_weight="1.3"
                    android:tag="action:delete"
                    android:text="DEL" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/key_symbol_toggle"
            style="@style/KeyboardKey"
            android:layout_weight="1.2"
            android:tag="action:symbol"
            android:text="123" />

        <Button
            android:id="@+id/key_mode"
            style="@style/KeyboardKey"
            android:layout_weight="1.0"
            android:tag="action:mode"
            android:text="ZH" />

        <Button
            style="@style/KeyboardKey"
            android:layout_weight="4.2"
            android:tag="action:space"
            android:text="space" />

        <Button
            style="@style/KeyboardKey"
            android:layout_weight="1.8"
            android:tag="action:enter"
            android:text="enter" />
    </LinearLayout>
</LinearLayout>
