<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F7F9"
    android:fillViewport="true"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="28dp"
        android:paddingEnd="24dp"
        android:paddingBottom="32dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="#20242C"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/version_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/app_version_display"
            android:textColor="#5A6472"
            android:textSize="16sp" />

        <TextView
            style="@style/SettingsSectionTitle"
            android:layout_marginTop="28dp"
            android:text="@string/settings_section_quick_test" />

        <EditText
            android:id="@+id/ime_test_input"
            style="@style/SettingsInputField"
            android:layout_marginTop="12dp"
            android:hint="@string/quick_test_input_hint"
            android:imeOptions="flagNoExtractUi"
            android:inputType="textMultiLine|textCapSentences"
            android:maxLines="6"
            android:minLines="4"
            android:overScrollMode="ifContentScrolls"
            android:scrollbars="vertical" />

        <TextView
            style="@style/SettingsSectionTitle"
            android:layout_marginTop="28dp"
            android:text="@string/settings_section_status" />

        <TextView
            android:id="@+id/dictionary_status"
            style="@style/SettingsBodyText"
            android:text="@string/dictionary_status_loading" />

        <TextView
            android:id="@+id/learned_data_status"
            style="@style/SettingsBodyText"
            android:layout_marginTop="10dp"
            android:text="@string/learned_data_status_placeholder" />

        <TextView
            style="@style/SettingsSectionTitle"
            android:layout_marginTop="28dp"
            android:text="@string/settings_section_manual_dictionary" />

        <TextView
            android:id="@+id/manual_dictionary_status"
            style="@style/SettingsBodyText"
            android:text="@string/manual_dictionary_status_placeholder" />

        <TextView
            android:id="@+id/manual_dictionary_result"
            style="@style/SettingsBodyText"
            android:text="@string/manual_dictionary_import_hint" />

        <Button
            android:id="@+id/import_manual_dictionary_button"
            style="@style/SettingsPrimaryButton"
            android:text="@string/import_manual_dictionary" />

        <Button
            android:id="@+id/export_dictionary_button"
            style="@style/SettingsSecondaryButton"
            android:layout_marginTop="10dp"
            android:text="@string/export_dictionary" />

        <Button
            android:id="@+id/clear_manual_dictionary_button"
            style="@style/SettingsSecondaryButton"
            android:layout_marginTop="10dp"
            android:text="@string/clear_manual_dictionary" />

        <TextView
            style="@style/SettingsSectionTitle"
            android:layout_marginTop="28dp"
            android:text="@string/settings_section_computer_manager" />

        <TextView
            android:id="@+id/computer_manager_status"
            style="@style/SettingsBodyText"
            android:text="@string/computer_manager_stopped" />

        <Button
            android:id="@+id/computer_manager_toggle_button"
            style="@style/SettingsPrimaryButton"
            android:text="@string/start_computer_manager" />

        <TextView
            style="@style/SettingsBodyText"
            android:text="@string/computer_manager_hint" />

        <TextView
            style="@style/SettingsSectionTitle"
            android:layout_marginTop="28dp"
            android:text="@string/settings_section_layout" />

        <TextView
            android:id="@+id/keyboard_layout_status"
            style="@style/SettingsBodyText"
            android:text="@string/keyboard_layout_status_26" />

        <Button
            android:id="@+id/keyboard_layout_toggle_button"
            style="@style/SettingsSecondaryButton"
            android:layout_marginTop="10dp"
            android:text="@string/switch_to_t9_layout" />

        <TextView
            style="@style/SettingsBodyText"
            android:text="@string/keyboard_layout_switch_hint" />

        <TextView
            style="@style/SettingsSectionTitle"
            android:layout_marginTop="28dp"
            android:text="@string/settings_section_actions" />

        <Button
            android:id="@+id/clear_learned_data_button"
            style="@style/SettingsPrimaryButton"
            android:text="@string/clear_learned_data" />

        <Button
            android:id="@+id/open_input_settings_button"
            style="@style/SettingsSecondaryButton"
            android:layout_marginTop="10dp"
            android:text="@string/open_input_settings" />

        <TextView
            style="@style/SettingsSectionTitle"
            android:layout_marginTop="28dp"
            android:text="@string/settings_section_enable" />

        <TextView
            style="@style/SettingsBodyText"
            android:text="@string/enable_ime_steps" />

        <TextView
            style="@style/SettingsSectionTitle"
            android:layout_marginTop="28dp"
            android:text="@string/settings_section_privacy" />

        <TextView
            style="@style/SettingsBodyText"
            android:text="@string/privacy_local_only" />
    </LinearLayout>
</ScrollView>
